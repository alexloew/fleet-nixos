{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "requiredStatusChecks": [
    "CI"
  ],
  "nix": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "packageRules": [
    {
      "matchManagers": [
        "nix",
        "github-actions"
      ],
      "automerge": true,
      "labels": [
        "dependencies"
      ]
    }
  ]
}
